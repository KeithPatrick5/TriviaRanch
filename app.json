{
  "expo": {
    "name": "Neon Trivia",
    "slug": "neon-trivia",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "neontrivia",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neontrivia.app"
    },
    "android": {
      "package": "com.neontrivia.app",
      "adaptiveIcon": {
        "backgroundColor": "#07051F",
        "foregroundImage": "./assets/brand/adaptive-icon.png"
      },
      "permissions": [],
      "splash": {
        "backgroundColor": "#020013",
        "resizeMode": "contain"
      }
    },
    "extra": {
      "eas": {
        "projectId": "replace-after-eas-init"
      }
    },
    "icon": "./assets/brand/app-icon.png",
    "splash": {
      "backgroundColor": "#020013",
      "resizeMode": "contain"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#020013",
      "translucent": false
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020013",
          "resizeMode": "contain"
        }
      ],
      "./plugins/withCleanAndroidLaunchSplash"
    ]
  }
}
